@prefix ex: <https://ljd6805.github.io/seminar_ai_ontology/ontology/failure#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

ex:SemiconductorFailureOntology a owl:Ontology ;
  dcterms:title "Semiconductor Regression Failure Ontology Example"@en ;
  dcterms:description "교육용 가상 예시: regression failure triage를 위한 작은 ontology."@ko ;
  owl:versionInfo "0.1.0" .

ex:TestFailure a owl:Class ;
  rdfs:label "Test failure"@en ;
  rdfs:comment "Regression 또는 simulation 실행에서 관측된 테스트 실패."@ko .

ex:TimeoutFailure a owl:Class ;
  rdfs:subClassOf ex:TestFailure ;
  rdfs:label "Timeout failure"@en ;
  rdfs:comment "정해진 시간 안에 테스트 또는 시뮬레이션이 종료되지 않은 실패."@ko .

ex:AssertionFailure a owl:Class ;
  rdfs:subClassOf ex:TestFailure ;
  rdfs:label "Assertion failure"@en .

ex:BuildFailure a owl:Class ;
  rdfs:subClassOf ex:TestFailure ;
  rdfs:label "Build failure"@en .

ex:EnvironmentFailure a owl:Class ;
  rdfs:subClassOf ex:TestFailure ;
  rdfs:label "Environment failure"@en .

ex:UnknownFailure a owl:Class ;
  rdfs:subClassOf ex:TestFailure ;
  rdfs:label "Unknown failure"@en ;
  rdfs:comment "근거가 부족해 자동 분류하지 않는 실패."@ko .

ex:RegressionRun a owl:Class ; rdfs:label "Regression run"@en .
ex:TestCase a owl:Class ; rdfs:label "Test case"@en .
ex:Evidence a owl:Class ; rdfs:label "Evidence"@en .
ex:JiraIssue a owl:Class ; rdfs:label "Jira issue"@en .
ex:IPBlock a owl:Class ; rdfs:label "IP block"@en .
ex:Engineer a owl:Class ; rdfs:label "Engineer"@en .

ex:failedTest a owl:ObjectProperty ;
  rdfs:domain ex:TestFailure ;
  rdfs:range ex:TestCase ;
  rdfs:label "failed test"@en .

ex:observedIn a owl:ObjectProperty ;
  rdfs:domain ex:TestFailure ;
  rdfs:range ex:RegressionRun ;
  rdfs:label "observed in"@en .

ex:hasEvidence a owl:ObjectProperty ;
  rdfs:domain ex:TestFailure ;
  rdfs:range ex:Evidence ;
  rdfs:label "has evidence"@en .

ex:relatedIssue a owl:ObjectProperty ;
  rdfs:domain ex:TestFailure ;
  rdfs:range ex:JiraIssue ;
  rdfs:label "related issue"@en .

ex:ownedBy a owl:ObjectProperty ;
  rdfs:range ex:Engineer ;
  rdfs:label "owned by"@en .

ex:hasSignature a owl:DatatypeProperty ;
  rdfs:domain ex:TestFailure ;
  rdfs:range xsd:string ;
  rdfs:label "has signature"@en .

ex:confidenceScore a owl:DatatypeProperty ;
  rdfs:domain ex:TestFailure ;
  rdfs:range xsd:decimal ;
  rdfs:label "confidence score"@en .

ex:nextAction a owl:DatatypeProperty ;
  rdfs:domain ex:TestFailure ;
  rdfs:range xsd:string ;
  rdfs:label "next action"@en .

ex:startedAt a owl:DatatypeProperty ;
  rdfs:domain ex:RegressionRun ;
  rdfs:range xsd:date ;
  rdfs:label "started at"@en .

ex:axi_burst_17 a ex:TestCase ;
  rdfs:label "axi_burst_17" .

ex:run_2026_07_21_nightly a ex:RegressionRun ;
  rdfs:label "2026-07-21 nightly regression" ;
  ex:startedAt "2026-07-21"^^xsd:date .

ex:evidence_1021_log_excerpt a ex:Evidence ;
  rdfs:label "AXI burst stalled log excerpt" ;
  dcterms:source "sim.log#L381-L420" .

ex:JIRA_431 a ex:JiraIssue ;
  rdfs:label "JIRA-431" .

ex:failure_1021 a ex:TimeoutFailure ;
  ex:failedTest ex:axi_burst_17 ;
  ex:observedIn ex:run_2026_07_21_nightly ;
  ex:hasSignature "AXI_BURST_STALL" ;
  ex:hasEvidence ex:evidence_1021_log_excerpt ;
  ex:relatedIssue ex:JIRA_431 ;
  ex:confidenceScore "0.74"^^xsd:decimal ;
  ex:nextAction "Check AXI monitor handshake and compare with JIRA-431" .
